# Copy to .env and edit. .env is gitignored.

# Public hostname. Use "localhost" for local dev (no TLS) or a real
# domain for production (Caddy fetches a Let's Encrypt cert).
DOMAIN=localhost

# Email for Let's Encrypt ACME. Optional but recommended in production.
EMAIL=

# Port the FastAPI app listens on inside the container. You usually
# don't need to change this — Caddy proxies to app:8080.
PORT=8080

# Set to 1 for uvicorn --reload in development.
DEBUG=0
