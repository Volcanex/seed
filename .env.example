# Copy to .env and edit. .env is gitignored.

# ─── Both modes ─────────────────────────────────────────────────────────
# Set to 1 for uvicorn --reload in development. Usually set via the
# docker-compose.override.yml dev file instead.
DEBUG=0

# Bind interface for `python3 server.py`. Default is 127.0.0.1 (loopback)
# so a local run doesn't expose the app on the LAN. Set 0.0.0.0 to bind
# all interfaces. The Docker image already does this internally.
# HOST=127.0.0.1

# ─── Behind a reverse proxy (default `docker compose up -d`) ────────────
# Loopback host port the app binds to. Your nginx/Caddy/Cloudflare
# tunnel proxies to this. Pick a free port per project on the host.
HOST_PORT=8080

# Compose project name — used as the container name prefix and image
# tag. Set this when running multiple seed-derived projects on one box.
# COMPOSE_PROJECT_NAME=my-site

# ─── Standalone (`docker compose --profile standalone up -d`) ───────────
# Used by Caddy for automatic TLS. Use a real hostname in production;
# `localhost` works for local testing without TLS.
DOMAIN=localhost

# Email for Let's Encrypt ACME registration. Optional but recommended.
EMAIL=

# ─── Admin auth (core/api/admin.py) ─────────────────────────────────────
# Set this for any deployment that exposes /admin/*. Default is "change-me"
# which is intentionally useless.
ADMIN_PASSWORD=

# Override the cookie name if you run multiple seed-derived apps on the
# same host and don't want them to collide.
# ADMIN_COOKIE=seed_admin

# Cookie Secure flag (1 = only sent over HTTPS). Default is on.
# Set to 0 only for HTTP-only deploys (rare; usually means TLS missing).
# ADMIN_COOKIE_SECURE=1

# ─── DB (core/db.py) ────────────────────────────────────────────────────
# Override SQLite location (e.g. point at a tmpfs in CI).
# SEED_DB_PATH=data/seed.db

# ─── Manifest auto-stub (compile.py) ────────────────────────────────────
# SEED_MANIFEST_PATH=data/manifest.json
# SEED_MANIFEST_PREFIX=item
# SEED_MANIFEST_TEMPLATE=stub.html
